{% doc %}
  @prompt
    Can you make a slim banner to announce 15% off all accessories for Valentine's day?
    Something red and that matches the rest of the homepage, I want to have the option of french texte for the french version of the website and also I would like to have the banner larger and with more hearts., Add a countdown under that ends next sunday at midnight (in french and english) and also a CTA for Shop all accessories., Can you have a line break after the «Ends in»? Also make the banner bigger and add a place for a button that leads to the Accessories collection and in french it says «MAGASINEZ MAINTENANT»
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-valentines-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color_1 }} 0%, {{ block.settings.background_color_2 }} 100%);
    padding: {{ block.settings.padding_vertical }}px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ai-valentines-banner-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .ai-valentines-banner-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    margin: 0 0 20px 0;
    line-height: 1.3;
  }

  .ai-valentines-banner-highlight-{{ ai_gen_id }} {
    color: {{ block.settings.highlight_color }};
    font-weight: 700;
  }

  .ai-valentines-banner-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    margin-left: 8px;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .ai-valentines-banner-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-valentines-banner-countdown-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .ai-valentines-banner-countdown-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size | times: 0.9 }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-valentines-banner-countdown-timer-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
  }

  .ai-valentines-banner-countdown-unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
  }

  .ai-valentines-banner-countdown-number-{{ ai_gen_id }} {
    color: {{ block.settings.highlight_color }};
    font-size: {{ block.settings.font_size | times: 1.8 }}px;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  .ai-valentines-banner-countdown-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size | times: 0.7 }}px;
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-valentines-banner-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 40px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    font-weight: 700;
    font-size: {{ block.settings.font_size | times: 0.95 }}px;
    border-radius: {{ block.settings.cta_border_radius }}px;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-valentines-banner-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    transform: translateY(-2px);
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }} {
    position: absolute;
    color: {{ block.settings.heart_color }};
    opacity: {{ block.settings.heart_opacity }};
    pointer-events: none;
    z-index: 1;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--1 {
    top: 50%;
    left: 3%;
    transform: translateY(-50%) rotate(-15deg);
    font-size: 40px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--2 {
    top: 50%;
    right: 3%;
    transform: translateY(-50%) rotate(15deg);
    font-size: 40px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--3 {
    top: 20%;
    left: 12%;
    transform: rotate(25deg);
    font-size: 24px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--4 {
    top: 20%;
    right: 12%;
    transform: rotate(-25deg);
    font-size: 24px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--5 {
    bottom: 20%;
    left: 8%;
    transform: rotate(-10deg);
    font-size: 28px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--6 {
    bottom: 20%;
    right: 8%;
    transform: rotate(10deg);
    font-size: 28px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--7 {
    top: 35%;
    left: 18%;
    transform: rotate(5deg);
    font-size: 18px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--8 {
    top: 35%;
    right: 18%;
    transform: rotate(-5deg);
    font-size: 18px;
  }

  @media screen and (max-width: 749px) {
    .ai-valentines-banner-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }

    .ai-valentines-banner-countdown-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }

    .ai-valentines-banner-countdown-timer-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-valentines-banner-countdown-unit-{{ ai_gen_id }} {
      min-width: 45px;
    }

    .ai-valentines-banner-countdown-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 1.4 }}px;
    }

    .ai-valentines-banner-countdown-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.6 }}px;
    }

    .ai-valentines-banner-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
      padding: 12px 28px;
    }

    .ai-valentines-banner-heart-{{ ai_gen_id }}--1,
    .ai-valentines-banner-heart-{{ ai_gen_id }}--2 {
      font-size: 28px;
    }

    .ai-valentines-banner-heart-{{ ai_gen_id }}--3,
    .ai-valentines-banner-heart-{{ ai_gen_id }}--4 {
      font-size: 18px;
    }

    .ai-valentines-banner-heart-{{ ai_gen_id }}--5,
    .ai-valentines-banner-heart-{{ ai_gen_id }}--6 {
      font-size: 20px;
    }

    .ai-valentines-banner-heart-{{ ai_gen_id }}--7,
    .ai-valentines-banner-heart-{{ ai_gen_id }}--8 {
      font-size: 14px;
    }

    .ai-valentines-banner-link-{{ ai_gen_id }} {
      display: block;
      margin-left: 0;
      margin-top: 4px;
    }
  }
{% endstyle %}

<valentines-banner-{{ ai_gen_id }}
  class="ai-valentines-banner-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.countdown_end_date }}"
  data-end-time="{{ block.settings.countdown_end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_hearts %}
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--1">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--2">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--3">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--4">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--5">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--6">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--7">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--8">♥</span>
  {% endif %}

  <div class="ai-valentines-banner-content-{{ ai_gen_id }}">
    <p class="ai-valentines-banner-text-{{ ai_gen_id }}">
      {% if request.locale.iso_code == 'fr' %}
        {{ block.settings.text_before_fr }}
        <span class="ai-valentines-banner-highlight-{{ ai_gen_id }}">{{ block.settings.discount_text_fr }}</span>
        {{ block.settings.text_after_fr }}
        {% if block.settings.link_url != blank %}
          <a href="{{ block.settings.link_url }}" class="ai-valentines-banner-link-{{ ai_gen_id }}">
            {{ block.settings.link_text_fr }}
          </a>
        {% endif %}
      {% else %}
        {{ block.settings.text_before_en }}
        <span class="ai-valentines-banner-highlight-{{ ai_gen_id }}">{{ block.settings.discount_text_en }}</span>
        {{ block.settings.text_after_en }}
        {% if block.settings.link_url != blank %}
          <a href="{{ block.settings.link_url }}" class="ai-valentines-banner-link-{{ ai_gen_id }}">
            {{ block.settings.link_text_en }}
          </a>
        {% endif %}
      {% endif %}
    </p>

    {% if block.settings.show_countdown %}
      <div class="ai-valentines-banner-countdown-{{ ai_gen_id }}">
        <p class="ai-valentines-banner-countdown-label-{{ ai_gen_id }}" data-label-en="{{ block.settings.countdown_label_en }}" data-label-fr="{{ block.settings.countdown_label_fr }}">
          {% if request.locale.iso_code == 'fr' %}
            {{ block.settings.countdown_label_fr }}
          {% else %}
            {{ block.settings.countdown_label_en }}
          {% endif %}
        </p>
        <div class="ai-valentines-banner-countdown-timer-{{ ai_gen_id }}">
          <div class="ai-valentines-banner-countdown-unit-{{ ai_gen_id }}">
            <div class="ai-valentines-banner-countdown-number-{{ ai_gen_id }}" data-days>0</div>
            <div class="ai-valentines-banner-countdown-text-{{ ai_gen_id }}" data-days-label-en="{{ block.settings.days_label_en }}" data-days-label-fr="{{ block.settings.days_label_fr }}">
              {% if request.locale.iso_code == 'fr' %}
                {{ block.settings.days_label_fr }}
              {% else %}
                {{ block.settings.days_label_en }}
              {% endif %}
            </div>
          </div>
          <div class="ai-valentines-banner-countdown-unit-{{ ai_gen_id }}">
            <div class="ai-valentines-banner-countdown-number-{{ ai_gen_id }}" data-hours>0</div>
            <div class="ai-valentines-banner-countdown-text-{{ ai_gen_id }}" data-hours-label-en="{{ block.settings.hours_label_en }}" data-hours-label-fr="{{ block.settings.hours_label_fr }}">
              {% if request.locale.iso_code == 'fr' %}
                {{ block.settings.hours_label_fr }}
              {% else %}
                {{ block.settings.hours_label_en }}
              {% endif %}
            </div>
          </div>
          <div class="ai-valentines-banner-countdown-unit-{{ ai_gen_id }}">
            <div class="ai-valentines-banner-countdown-number-{{ ai_gen_id }}" data-minutes>0</div>
            <div class="ai-valentines-banner-countdown-text-{{ ai_gen_id }}" data-minutes-label-en="{{ block.settings.minutes_label_en }}" data-minutes-label-fr="{{ block.settings.minutes_label_fr }}">
              {% if request.locale.iso_code == 'fr' %}
                {{ block.settings.minutes_label_fr }}
              {% else %}
                {{ block.settings.minutes_label_en }}
              {% endif %}
            </div>
          </div>
          <div class="ai-valentines-banner-countdown-unit-{{ ai_gen_id }}">
            <div class="ai-valentines-banner-countdown-number-{{ ai_gen_id }}" data-seconds>0</div>
            <div class="ai-valentines-banner-countdown-text-{{ ai_gen_id }}" data-seconds-label-en="{{ block.settings.seconds_label_en }}" data-seconds-label-fr="{{ block.settings.seconds_label_fr }}">
              {% if request.locale.iso_code == 'fr' %}
                {{ block.settings.seconds_label_fr }}
              {% else %}
                {{ block.settings.seconds_label_en }}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.cta_url != blank %}
      <a href="{{ block.settings.cta_url }}" class="ai-valentines-banner-cta-{{ ai_gen_id }}">
        {% if request.locale.iso_code == 'fr' %}
          {{ block.settings.cta_text_fr }}
        {% else %}
          {{ block.settings.cta_text_en }}
        {% endif %}
      </a>
    {% endif %}
  </div>
</valentines-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ValentinesBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        if (this.endDate && this.endTime) {
          this.startCountdown();
        }
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        const endDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();
        
        const updateCountdown = () => {
          const now = new Date().getTime();
          const distance = endDateTime - now;

          if (distance < 0) {
            if (this.interval) {
              clearInterval(this.interval);
            }
            this.querySelector('[data-days]').textContent = '0';
            this.querySelector('[data-hours]').textContent = '0';
            this.querySelector('[data-minutes]').textContent = '0';
            this.querySelector('[data-seconds]').textContent = '0';
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          const daysEl = this.querySelector('[data-days]');
          const hoursEl = this.querySelector('[data-hours]');
          const minutesEl = this.querySelector('[data-minutes]');
          const secondsEl = this.querySelector('[data-seconds]');

          if (daysEl) daysEl.textContent = days;
          if (hoursEl) hoursEl.textContent = hours;
          if (minutesEl) minutesEl.textContent = minutes;
          if (secondsEl) secondsEl.textContent = seconds;
        };

        updateCountdown();
        this.interval = setInterval(updateCountdown, 1000);
      }
    }

    customElements.define('valentines-banner-{{ ai_gen_id }}', ValentinesBanner{{ ai_gen_id }});
  })();
</script>

