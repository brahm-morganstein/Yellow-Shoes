<link rel="stylesheet" href="//code.jquery.com/ui/1.13.1/themes/base/jquery-ui.css">
<script src="https://code.jquery.com/ui/1.13.1/jquery-ui.js" defer></script>
{% if shop.locale == 'fr' %}
  <script src="https://jqueryui.com/resources/demos/datepicker/i18n/datepicker-fr.js" defer></script>
{% endif%}

<div class="container fully-spaced-row--small" style="--page-container-width: {{ settings.max_page_width | at_most: 1200 }}px;">
  <a
    class="customer-profile-back-link"
    href="{{ routes.account_url }}"
    onclick="if (window.history.length > 1) { history.back(); return false; }"
  >
    <span aria-hidden="true">&larr;</span>
    {{ 'customer.account.return' | t }}
  </a>

  {% if customer %}
    {% render 'customer.profile.styles' %}
    {% render 'customer.profile' %}
    {% render 'customer.profile.behavior' %}
  {% else %}
    <div class="align-center" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
      <h2 class="title">{{ 'customer.login.title' | t }}</h2>
      <p>
        <a class="btn" href="{{ routes.account_login_url }}?return_url={{ request.path }}">
          {{ 'customer.login.submit' | t }}
        </a>
      </p>
    </div>
  {% endif %}
</div>

<style>
  .customer-profile-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    color: rgb(var(--body-text-color));
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .customer-profile-back-link:hover {
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "Customer profile page",
  "class": "page-section-spacing",
  "settings": []
}
{% endschema %}
