{% doc %}
  @prompt
    Can you make a slim banner to announce 15% off all accessories for Valentine's day?
    Something red and that matches the rest of the homepage
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-valentines-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color_1 }} 0%, {{ block.settings.background_color_2 }} 100%);
    padding: {{ block.settings.padding_vertical }}px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ai-valentines-banner-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .ai-valentines-banner-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-valentines-banner-highlight-{{ ai_gen_id }} {
    color: {{ block.settings.highlight_color }};
    font-weight: 700;
  }

  .ai-valentines-banner-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    margin-left: 8px;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .ai-valentines-banner-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }} {
    position: absolute;
    color: {{ block.settings.heart_color }};
    opacity: {{ block.settings.heart_opacity }};
    pointer-events: none;
    z-index: 1;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--1 {
    top: 50%;
    left: 5%;
    transform: translateY(-50%) rotate(-15deg);
    font-size: 24px;
  }

  .ai-valentines-banner-heart-{{ ai_gen_id }}--2 {
    top: 50%;
    right: 5%;
    transform: translateY(-50%) rotate(15deg);
    font-size: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-valentines-banner-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.85 }}px;
    }

    .ai-valentines-banner-heart-{{ ai_gen_id }} {
      font-size: 18px;
    }

    .ai-valentines-banner-link-{{ ai_gen_id }} {
      display: block;
      margin-left: 0;
      margin-top: 4px;
    }
  }
{% endstyle %}

<valentines-banner-{{ ai_gen_id }}
  class="ai-valentines-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_hearts %}
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--1">♥</span>
    <span class="ai-valentines-banner-heart-{{ ai_gen_id }} ai-valentines-banner-heart-{{ ai_gen_id }}--2">♥</span>
  {% endif %}

  <div class="ai-valentines-banner-content-{{ ai_gen_id }}">
    <p class="ai-valentines-banner-text-{{ ai_gen_id }}">
      {{ block.settings.text_before }}
      <span class="ai-valentines-banner-highlight-{{ ai_gen_id }}">{{ block.settings.discount_text }}</span>
      {{ block.settings.text_after }}
      {% if block.settings.link_url != blank %}
        <a href="{{ block.settings.link_url }}" class="ai-valentines-banner-link-{{ ai_gen_id }}">
          {{ block.settings.link_text }}
        </a>
      {% endif %}
    </p>
  </div>
</valentines-banner-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Valentine's day banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "text_before",
      "label": "Text before discount",
      "default": "Valentine's Day Special:"
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Discount text",
      "default": "15% off all accessories"
    },
    {
      "type": "text",
      "id": "text_after",
      "label": "Text after discount",
      "default": "— Limited time only"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color_1",
      "label": "Background start",
      "default": "#c20000"
    },
    {
      "type": "color",
      "id": "background_color_2",
      "label": "Background end",
      "default": "#8b0000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Discount highlight",
      "default": "#ffebcd"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Decorative hearts"
    },
    {
      "type": "checkbox",
      "id": "show_hearts",
      "label": "Show hearts",
      "default": true
    },
    {
      "type": "color",
      "id": "heart_color",
      "label": "Heart color",
      "default": "#ff69b4"
    },
    {
      "type": "range",
      "id": "heart_opacity",
      "label": "Heart opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.2
    }
  ],
  "presets": [
    {
      "name": "Valentine's day banner"
    }
  ]
}
{% endschema %}
