{% doc %}
  @prompt
    Can you make a slim banner to announce 15% off all accessories for Valentine's day?
    Something red and that matches the rest of the homepage, I want to have the option of french texte for the french version of the website and also I would like to have the banner larger and with more hearts., Add a countdown under that ends next sunday at midnight (in french and english) and also a CTA for Shop all accessories., Can you have a line break after the «Ends in»? Also make the banner bigger and add a place for a button that leads to the Accessories collection and in french it says «MAGASINEZ MAINTENANT»
    Can the title be the big piece of the banner please?
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% comment %} Calculate countdown end date - next Sunday at midnight EST {% endcomment %}
{% assign current_date = 'now' | date: '%s' %}
{% assign current_day = 'now' | date: '%w' %}
{% assign days_until_sunday = 7 | minus: current_day %}
{% assign seconds_until_sunday = days_until_sunday | times: 86400 %}
{% assign sunday_timestamp = current_date | plus: seconds_until_sunday %}
{% assign end_date = sunday_timestamp | date: '%Y-%m-%d' %}

{% style %}
  .ai-valentine-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color }} 0%, {{ block.settings.background_gradient_color }} 100%);
    padding: 40px 20px;
    position: relative;
    overflow: hidden;
  }

  .ai-valentine-banner-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .ai-valentine-banner-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-valentine-banner-countdown-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_label_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-valentine-banner-countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .ai-valentine-banner-countdown-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 70px;
  }

  .ai-valentine-banner-countdown-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }

  .ai-valentine-banner-countdown-label-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_label_text_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-valentine-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 700;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-valentine-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }} {
    position: absolute;
    color: {{ block.settings.heart_color }};
    opacity: {{ block.settings.heart_opacity }};
    pointer-events: none;
    z-index: 1;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--1 {
    top: 10%;
    left: 5%;
    font-size: 40px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--2 {
    top: 20%;
    right: 8%;
    font-size: 30px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--3 {
    bottom: 15%;
    left: 10%;
    font-size: 35px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--4 {
    bottom: 25%;
    right: 12%;
    font-size: 25px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--5 {
    top: 50%;
    left: 15%;
    font-size: 20px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--6 {
    top: 60%;
    right: 18%;
    font-size: 28px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--7 {
    top: 35%;
    left: 3%;
    font-size: 22px;
  }

  .ai-valentine-banner-heart-{{ ai_gen_id }}--8 {
    bottom: 40%;
    right: 5%;
    font-size: 32px;
  }

  @media screen and (max-width: 749px) {
    .ai-valentine-banner-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-valentine-banner-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.6 }}px;
      margin-bottom: 16px;
    }

    .ai-valentine-banner-countdown-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.countdown_label_size | times: 0.8 }}px;
    }

    .ai-valentine-banner-countdown-{{ ai_gen_id }} {
      gap: 12px;
      margin-bottom: 20px;
    }

    .ai-valentine-banner-countdown-item-{{ ai_gen_id }} {
      min-width: 60px;
    }

    .ai-valentine-banner-countdown-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.countdown_size | times: 0.7 }}px;
    }

    .ai-valentine-banner-countdown-label-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.countdown_label_text_size | times: 0.8 }}px;
    }

    .ai-valentine-banner-button-{{ ai_gen_id }} {
      padding: 14px 32px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }

    .ai-valentine-banner-heart-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<valentine-countdown-{{ ai_gen_id }}
  class="ai-valentine-banner-{{ ai_gen_id }}"
  data-end-date="{{ end_date }}T23:59:59-05:00"
  {{ block.shopify_attributes }}
>
  {% for i in (1..8) %}
    <div class="ai-valentine-banner-heart-{{ ai_gen_id }} ai-valentine-banner-heart-{{ ai_gen_id }}--{{ i }}">
      ❤
    </div>
  {% endfor %}

  <div class="ai-valentine-banner-container-{{ ai_gen_id }}">
    <h2 class="ai-valentine-banner-title-{{ ai_gen_id }}">
      {% if block.settings.language == 'french' %}
        {{ block.settings.title_french }}
      {% else %}
        {{ block.settings.title_english }}
      {% endif %}
    </h2>

    <div class="ai-valentine-banner-countdown-label-{{ ai_gen_id }}">
      {% if block.settings.language == 'french' %}
        {{ block.settings.countdown_label_french }}
      {% else %}
        {{ block.settings.countdown_label_english }}
      {% endif %}
    </div>

    <div class="ai-valentine-banner-countdown-{{ ai_gen_id }}">
      <div class="ai-valentine-banner-countdown-item-{{ ai_gen_id }}">
        <div class="ai-valentine-banner-countdown-number-{{ ai_gen_id }}" data-days>0</div>
        <div class="ai-valentine-banner-countdown-label-text-{{ ai_gen_id }}">
          {% if block.settings.language == 'french' %}
            Jours
          {% else %}
            Days
          {% endif %}
        </div>
      </div>
      <div class="ai-valentine-banner-countdown-item-{{ ai_gen_id }}">
        <div class="ai-valentine-banner-countdown-number-{{ ai_gen_id }}" data-hours>0</div>
        <div class="ai-valentine-banner-countdown-label-text-{{ ai_gen_id }}">
          {% if block.settings.language == 'french' %}
            Heures
          {% else %}
            Hours
          {% endif %}
        </div>
      </div>
      <div class="ai-valentine-banner-countdown-item-{{ ai_gen_id }}">
        <div class="ai-valentine-banner-countdown-number-{{ ai_gen_id }}" data-minutes>0</div>
        <div class="ai-valentine-banner-countdown-label-text-{{ ai_gen_id }}">
          {% if block.settings.language == 'french' %}
            Minutes
          {% else %}
            Minutes
          {% endif %}
        </div>
      </div>
      <div class="ai-valentine-banner-countdown-item-{{ ai_gen_id }}">
        <div class="ai-valentine-banner-countdown-number-{{ ai_gen_id }}" data-seconds>0</div>
        <div class="ai-valentine-banner-countdown-label-text-{{ ai_gen_id }}">
          {% if block.settings.language == 'french' %}
            Secondes
          {% else %}
            Seconds
          {% endif %}
        </div>
      </div>
    </div>

    {% if block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-valentine-banner-button-{{ ai_gen_id }}">
        {% if block.settings.language == 'french' %}
          {{ block.settings.button_text_french }}
        {% else %}
          {{ block.settings.button_text_english }}
        {% endif %}
      </a>
    {% endif %}
  </div>
</valentine-countdown-{{ ai_gen_id }}>

<script>
  (function() {
    class ValentineCountdown{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = new Date(this.dataset.endDate);
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
      }

      connectedCallback() {
        this.updateCountdown();
        this.interval = setInterval(() => this.updateCountdown(), 1000);
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      updateCountdown() {
        const now = new Date().getTime();
        const distance = this.endDate.getTime() - now;

        if (distance < 0) {
          this.daysEl.textContent = '0';
          this.hoursEl.textContent = '0';
          this.minutesEl.textContent = '0';
          this.secondsEl.textContent = '0';
          clearInterval(this.interval);
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.daysEl.textContent = days;
        this.hoursEl.textContent = hours;
        this.minutesEl.textContent = minutes;
        this.secondsEl.textContent = seconds;
      }
    }

    customElements.define('valentine-countdown-{{ ai_gen_id }}', ValentineCountdown{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
